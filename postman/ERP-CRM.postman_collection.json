            "url": {
              "raw": "{{baseUrl}}/customers/:id/followups",
              "host": ["{{baseUrl}}"],
              "path": ["customers", ":id", "followups"],
              "variable": [
                {
                  "key": "id",
                  "value": ""
                }
              ]
            }
          }
        }
      ]
    },
